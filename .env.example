# Discord credentials (from Discord Developer Portal → Bot tab)
DISCORD_TOKEN=
BOT_USER_ID=

# Your Discord server ID — right-click server icon → Copy Server ID (Developer Mode on)
# Primary server for commit-summary channel, escalation bind, etc.
DISCORD_GUILD_ID=

# Optional: extra guild IDs (comma-separated) to force slash command registration
# DISCORD_GUILD_IDS=1520007904156061837,123456789012345678

# n8n webhook — copy from the active "Discord → Linear Bot" workflow
# Production: https://n8n.techflowlabs.gr/webhook/discord-linear-bot
N8N_WEBHOOK=

# n8n REST API key (Settings → API) — for workflow management / MCP dashboard
N8N_API_KEY=

# Linear workspace slug (from linear.app URLs, e.g. techflowlabs)
LINEAR_WORKSPACE=techflowlabs

# GitHub org + PAT (fine-grained token, Resource owner: TechFlow-Labs)
# See docs/setup-checklist.md for full permission list and repo access
GITHUB_ORG=TechFlow-Labs
GITHUB_TOKEN=

# Repo for /deploy (owner/repo — may differ from GITHUB_ORG)
GITHUB_REPO=semantic-software/EmblemTameiaki

# OpenAI API key — AI code edits on `go` + commit reviews + sales support
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# DEV_ASSISTANT_MODEL=gpt-4o   # optional override for /dev

# --- Sales & customer support (/sales-support) ---
# Primary knowledge: EmblemTameiaki-Knowledge (local clone)
KNOWLEDGE_REPO_PATH=/Users/konstantinospeltekis/Documents/GitHub/EmblemTameiaki-Knowledge
# Wiki docs branch (read via git — no checkout needed). Set empty to use working tree.
KNOWLEDGE_REPO_BRANCH=ai/sales-support-knowledge
# Fetch origin before reading branch (recommended when vendor/ PDFs change on remote)
KNOWLEDGE_REPO_FETCH=true
# EmblemTameiaki unified context: code activity depth (optional)
# CODE_ACTIVITY_BRANCHES=0   # 0 or unset = all branches
# CODE_ACTIVITY_DEFAULT_COMMITS=40
# CODE_ACTIVITY_MERGED_PRS=50
# CODE_ACTIVITY_MAX_CHARS=42000
# FAQ catalog: data/faq/emblem-tamiaki.md
# Stored commit reviews (reusable): data/reviews/{owner}__{repo}.json

# --- Semantic retrieval (embeddings vector index at data/vector/) ---
# Replaces keyword caps for specific questions. Build with `npm run kb:reindex`.
# EMBEDDING_MODEL=text-embedding-3-small
# RETRIEVAL_TOP_K=24
# RETRIEVAL_TOKEN_BUDGET=40000
# RETRIEVAL_THRESHOLD=0.16
# INDEX_CHUNK_CHARS=3000
# INDEX_CHUNK_OVERLAP=400
# Optional grounded second-pass factuality check (extra model call per answer)
# ANSWER_VERIFY=true
# ANSWER_VERIFY_MODEL=gpt-4o-mini

# --- Assistant hub (auto-thread per slash command in hub channel) ---
# Defaults to KNOWLEDGE_CAPTURE_CHANNELS when unset.
# ASSISTANT_HUB_CHANNELS=1524663908894249010

# --- Discord knowledge capture (bug/fix/problem→solution) ---
# Passive raw logging of designated channels → data/discord-capture/{channelId}.jsonl
# KNOWLEDGE_CAPTURE_ENABLED=true
# Comma-separated channel IDs (threads under them are captured too)
# KNOWLEDGE_CAPTURE_CHANNELS=
# React with this emoji (or reply "kb save") to promote a solved thread
# KNOWLEDGE_SOLVE_EMOJI=✅
# Model used to extract the structured solution (defaults to OPENAI_MODEL)
# KNOWLEDGE_EXTRACT_MODEL=gpt-4o
# Review channel: extraction previews are posted here for maintainer approval
# KNOWLEDGE_REVIEW_CHANNEL=
# KNOWLEDGE_APPROVE_EMOJI=✅
# On approval, open a PR to this repo/branch (defaults to KNOWLEDGE_REPO_BRANCH)
# KNOWLEDGE_GITHUB_REPO=semantic-software/EmblemTameiaki-Knowledge
# History import limit per channel/thread (scripts/import-discord-history.js)
# KB_IMPORT_LIMIT=500

# --- Auto commit review (poll GitHub → AI → #commit-summary + store) ---
COMMIT_AUTO_REVIEW=true
COMMIT_AUTO_REVIEW_REPO=semantic-software/EmblemTameiaki
# COMMIT_AUTO_REVIEW_POLL_MINUTES=10
# COMMIT_AUTO_REVIEW_BACKFILL=8

# --- Commit review webhook (instant on push; optional alongside poll) ---
# COMMIT_REVIEW_ENABLED=true
# Random secret — paste the same value in GitHub webhook settings
GITHUB_WEBHOOK_SECRET=
# Local port for the bridge webhook server (default 3847)
WEBHOOK_PORT=3847
# Public URL GitHub can reach (tunnel or VPS), e.g. https://bridge.techflowlabs.gr
WEBHOOK_PUBLIC_URL=
# Channel name (default Commit-Summary) or set ID directly
DISCORD_COMMIT_SUMMARY_CHANNEL=Commit-Summary
# DISCORD_COMMIT_SUMMARY_CHANNEL_ID=
# Optional: only review these repos (comma-separated names or owner/repo)
# COMMIT_REVIEW_REPOS=wed-main-mvp,web-video-call-transcription

# Optional: more repos in the commit-summary picker (comma-separated owner/repo)
# COMMIT_SUMMARY_EXTRA_REPOS=semantic-software/EmblemTameiaki
# Default label on /github-issue (retries without missing labels if repo rejects them)
# GITHUB_ISSUE_LABEL=discord
# GITHUB_ISSUE_CLASSIFY_MODEL=gpt-4o-mini
# PLAN_TTL_MINUTES=30

# Optional: DM-only mode (default true). Set false to also respond to @mentions in servers.
# DM_ONLY=true

# --- Auto-escalation (unanswered questions in QA / build channels) ---
# Watches config/escalation.json — tags dev roles + DMs them after timeout (default 40m).
# Enable Server Members Intent in Discord Developer Portal for role DMs.
# ESCALATION_ENABLED=true
# ESCALATION_MINUTES=40
# ESCALATION_AUTO_HINT=true          # instant non-dev guidance for testers (escalation still runs)
# ESCALATION_HINT_MODEL=gpt-4o-mini
# Channel IDs auto-resolve by name on boot. Override per channel if needed:
# ESCALATION_CHANNEL_tameiaki-testing=123456789012345678
# ESCALATION_CHANNEL_features=123456789012345678
# ESCALATION_CHANNEL_android=123456789012345678
# ESCALATION_CHANNEL_tameiaki-ios=123456789012345678
# ESCALATION_CHANNEL_pos-semantic=123456789012345678
# Edit routing roles in config/escalation.json (ownerRole = exact Discord role name, like DEPLOY_ROLES)
